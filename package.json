{
	"name": "my-app",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"services:up": "docker compose --env-file .env -f src/infra/composer.yml up -d",
		"services:down": "docker compose --env-file .env -f src/infra/composer.yml down",
		"migrations:generate": "bun run scripts/generate-migration.ts",
		"migrations:apply": "bunx drizzle-kit migrate",
		"dev": "bun run --watch src/index.ts"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/figlet": "^1.7.0",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.22.4"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"elysia": "^1.4.29",
		"figlet": "^1.11.0",
		"pg": "^8.22.0"
	}
}
