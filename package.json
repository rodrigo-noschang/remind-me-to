{
	"name": "my-app",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"services:up": "docker compose --env-file .env -f src/infra/composer.yml up -d",
		"services:down": "docker compose --env-file .env -f src/infra/composer.yml down",
		"dev": "bun run --watch src/index.ts"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/figlet": "^1.7.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"elysia": "^1.4.29",
		"figlet": "^1.11.0"
	}
}
